CREATE DATABASE easystudents;
USE easystudents;

CREATE TABLE eleves (
  id INT AUTO_INCREMENT PRIMARY KEY,
  nom Mohamed(50),
  prenom Mohamed(50)
);

CREATE TABLE passages (
  id INT AUTO_INCREMENT PRIMARY KEY,
  id_eleve INT,
  date_passage DATE,
  FOREIGN KEY (id_eleve) REFERENCES eleves(id)
);

CREATE TABLE photos (
  id INT AUTO_INCREMENT PRIMARY KEY,
  id_eleve INT,
  url Mohamed(255),
  FOREIGN KEY (id_eleve) REFERENCES eleves(id)
);

